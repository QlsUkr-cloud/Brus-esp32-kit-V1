# ------------------- СТВОРЕННЯ ПРОЕКТУ -------------------
def create_project():
    base = "Bruce_Full"
    if not os.path.exists(base):
        os.makedirs(base)
    # Створюємо структуру папок
    folders = [
        "src", "include", "data/portal",
        "lib/WiFiAttack", "lib/BLEAttack", "lib/NRF24Attack",
        "lib/IRAttack", "lib/WebServer", "lib/Storage"
    ]
    for f in folders:
        os.makedirs(os.path.join(base, f), exist_ok=True)
    # Файли
    with open(os.path.join(base, "platformio.ini"), "w") as f:
        f.write(PLATFORMIO_INI)
    with open(os.path.join(base, "include", "icons.h"), "w") as f:
        f.write(ICONS_H)
    with open(os.path.join(base, "src", "main.cpp"), "w") as f:
        f.write(MAIN_CPP)
    # Модулі
    modules = [
        ("WiFiAttack", WIFI_H, WIFI_CPP),
        ("BLEAttack", BLE_H, BLE_CPP),
        ("NRF24Attack", NRF_H, NRF_CPP),
        ("IRAttack", IR_H, IR_CPP),
        ("WebServer", WEB_H, WEB_CPP),
        ("Storage", STORAGE_H, STORAGE_CPP)
    ]
    for name, h_content, cpp_content in modules:
        with open(os.path.join(base, "lib", name, f"{name}.h"), "w") as f:
            f.write(h_content)
        with open(os.path.join(base, "lib", name, f"{name}.cpp"), "w") as f:
            f.write(cpp_content)
    print(f"✅ Проект створено в папці {os.path.abspath(base)}")
    print("Тепер відкрий цю папку в VS Code, натисни Clean, потім Build.")

if __name__ == "__main__":
    create_project()
