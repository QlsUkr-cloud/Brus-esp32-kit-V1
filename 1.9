[env:esp32dev]
platform = espressif32
board = esp32dev
framework = arduino
monitor_speed = 115200
upload_speed = 921600
board_build.filesystem = littlefs

lib_deps =
    olikraus/U8g2@^2.35.15
    nrf24/RF24@^1.4.11
    h2zero/NimBLE-Arduino@^2.3.9
    crankyoldgit/IRremoteESP8266@^2.8.6
    bblanchon/ArduinoJson@^7.4.2
