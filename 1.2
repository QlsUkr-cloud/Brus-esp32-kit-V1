# ==================== ГОЛОВНИЙ ФАЙЛ main.cpp (з меню, як у твоєму прикладі) ====================
MAIN_CPP = r'''#include <Arduino.h>
#include <U8g2lib.h>
#include <Wire.h>
#include "icons.h"

// ==================== ПІНИ КНОПОК ====================
#define BTN_UP     15
#define BTN_DOWN   13
#define BTN_OK     12
#define BTN_LEFT   14
#define BTN_RIGHT  27
#define BTN_BACK   26

// ==================== OLED ====================
U8G2_SSD1306_128X64_NONAME_F_HW_I2C u8g2(U8G2_R0, U8X8_PIN_NONE, 22, 21);

// ==================== СТРУКТУРА МЕНЮ ====================
struct SubItem {
    const char* name;
    const unsigned char* icon12;
};

struct MainItem {
    const char* name;
    const unsigned char* icon40;
    const unsigned char* icon24;
    SubItem* subs;
    int cnt;
};

SubItem subWifi[] = {
    {"Scan Networks", ICO12_SCAN},
    {"Monitor", ICO12_SCAN},
    {"WiFi Info", ICO12_INFO},
};
SubItem subBLE[] = {
    {"Scan Devices", ICO12_SCAN},
    {"BLE Info", ICO12_INFO},
};
SubItem subNRF[] = {
    {"Scanner", ICO12_SCAN},
    {"Sender", ICO12_SEND},
    {"NRF Info", ICO12_INFO},
};
SubItem subIR[] = {
    {"TV Remote", ICO12_TV},
    {"AC Remote", ICO12_RF},
    {"Custom Code", ICO12_RF},
};
SubItem subSet[] = {
    {"NRF Channel", ICO12_RF},
    {"Brightness", ICO12_BRIGHT},
    {"About", ICO12_INFO},
};

MainItem menu[] = {
    {"WiFi", ICO40_WIFI, ICO24_WIFI, subWifi, 3},
    {"BLE", ICO40_BLE, ICO24_BLE, subBLE, 2},
    {"NRF24", ICO40_NRF, ICO24_NRF, subNRF, 3},
    {"IR", ICO40_IR, ICO24_IR, subIR, 3},
    {"Settings", ICO40_SET, ICO24_SET, subSet, 3},
};
const int MCNT = 5;

enum State { ST_MAIN, ST_SUB };
State state = ST_MAIN;
int mainIdx = 0, subIdx = 0, subScroll = 0;
unsigned long bootMs = 0;
bool wifiOn = false, webOn = false;

unsigned long lastBtn = 0;
#define DEBOUNCE 200
bool btn(int pin) {
    if (!digitalRead(pin) && millis() - lastBtn > DEBOUNCE) {
        lastBtn = millis();
        return true;
    }
    return false;
}

void drawTopBar() {
    u8g2.drawBox(0, 0, 128, 10);
    u8g2.setDrawColor(0);
    u8g2.setFont(u8g2_font_5x7_tr);
    unsigned long sec = (millis() - bootMs) / 1000;
    int h = (12 * 3600 + sec) / 3600 % 24;
    int m = ((12 * 3600 + sec) % 3600) / 60;
    char tb[8];
    sprintf(tb, "%02d:%02d", h, m);
    u8g2.drawStr(2, 8, tb);
    if (wifiOn) u8g2.drawStr(40, 8, "W");
    if (webOn) u8g2.drawStr(50, 8, "@");
    u8g2.drawFrame(112, 2, 13, 6);
    u8g2.drawBox(125, 4, 2, 2);
    u8g2.drawBox(113, 3, 9, 4);
    u8g2.setDrawColor(1);
    u8g2.drawHLine(0, 10, 128);
}

void animDown() {
    for (int y = 64; y >= 11; y -= 9) {
        u8g2.clearBuffer();
        drawTopBar();
        u8g2.drawRFrame(8, y, 112, 48, 3);
        u8g2.sendBuffer();
        delay(10);
    }
}
void animUp() {
    for (int y = 11; y <= 64; y += 9) {
        u8g2.clearBuffer();
        drawTopBar();
        u8g2.drawRFrame(8, y, 112, 48, 3);
        u8g2.sendBuffer();
        delay(10);
    }
}

void drawMainMenu() {
    u8g2.clearBuffer();
    drawTopBar();
    int prev = (mainIdx - 1 + MCNT) % MCNT;
    int next = (mainIdx + 1) % MCNT;
    u8g2.drawXBM(2, 17, 24, 24, menu[prev].icon24);
    u8g2.drawXBM(102, 17, 24, 24, menu[next].icon24);
    u8g2.drawXBM(44, 12, 40, 40, menu[mainIdx].icon40);
    u8g2.setFont(u8g2_font_7x13B_tr);
    u8g2.drawStr(28, 36, "<");
    u8g2.drawStr(93, 36, ">");
    u8g2.setFont(u8g2_font_6x10_tr);
    int nw = u8g2.getStrWidth(menu[mainIdx].name);
    u8g2.drawStr((128 - nw) / 2, 55, menu[mainIdx].name);
    int dotW = MCNT * 9 - 1;
    int dx = (128 - dotW) / 2;
    for (int i = 0; i < MCNT; i++) {
        if (i == mainIdx) u8g2.drawBox(dx + i * 9, 59, 6, 5);
        else u8g2.drawFrame(dx + i * 9, 59, 6, 5);
    }
    u8g2.sendBuffer();
}

void drawSubMenu() {
    MainItem& m = menu[mainIdx];
    const int ROWS = 3, RH = 13;
    if (subIdx < subScroll) subScroll = subIdx;
    if (subIdx >= subScroll + ROWS) subScroll = subIdx - ROWS + 1;
    u8g2.clearBuffer();
    drawTopBar();
    u8g2.drawBox(0, 11, 128, 12);
    u8g2.setDrawColor(0);
    u8g2.drawXBM(2, 12, 10, 10, m.icon24);
    u8g2.setFont(u8g2_font_6x10_tr);
    u8g2.drawStr(15, 21, m.name);
    u8g2.setDrawColor(1);
    for (int i = 0; i < ROWS && (subScroll + i) < m.cnt; i++) {
        int ri = subScroll + i;
        int y = 23 + i * RH;
        if (ri == subIdx) {
            u8g2.drawBox(0, y, 120, RH);
            u8g2.setDrawColor(0);
            u8g2.drawXBM(2, y + 1, 12, 12, ICO12_FOLDER);
            u8g2.drawXBM(16, y + 1, 12, 12, m.subs[ri].icon12);
            u8g2.setFont(u8g2_font_5x7_tr);
            u8g2.drawStr(30, y + 9, m.subs[ri].name);
            u8g2.setDrawColor(1);
        } else {
            u8g2.drawXBM(2, y + 1, 12, 12, ICO12_FOLDER);
            u8g2.drawXBM(16, y + 1, 12, 12, m.subs[ri].icon12);
            u8g2.setFont(u8g2_font_5x7_tr);
            u8g2.drawStr(30, y + 9, m.subs[ri].name);
        }
    }
    for (int y = 23; y < 62; y += 2) u8g2.drawPixel(126, y);
    if (m.cnt > ROWS) {
        int bh = max(5, (39 * ROWS) / m.cnt);
        int by = 23 + (subScroll * (39 - bh)) / max(1, m.cnt - ROWS);
        u8g2.drawBox(124, by, 3, bh);
    }
    u8g2.sendBuffer();
}

void showMessage(const char* msg, int delayMs = 1500) {
    u8g2.clearBuffer();
    drawTopBar();
    u8g2.drawBox(0, 11, 128, 12);
    u8g2.setDrawColor(0);
    u8g2.setFont(u8g2_font_6x10_tr);
    u8g2.drawStr(4, 21, "[ INFO ]");
    u8g2.setDrawColor(1);
    u8g2.setFont(u8g2_font_6x10_tr);
    u8g2.drawStr(10, 38, msg);
    u8g2.setFont(u8g2_font_5x7_tr);
    u8g2.drawStr(10, 52, "BACK = exit");
    u8g2.sendBuffer();
    while (!btn(BTN_BACK)) delay(50);
}

void executeAction() {
    MainItem& m = menu[mainIdx];
    const char* actionName = m.subs[subIdx].name;
    char buf[32];
    sprintf(buf, "Run: %s", actionName);
    showMessage(buf);
}

void setup() {
    pinMode(BTN_UP, INPUT_PULLUP);
    pinMode(BTN_DOWN, INPUT_PULLUP);
    pinMode(BTN_OK, INPUT_PULLUP);
    pinMode(BTN_LEFT, INPUT_PULLUP);
    pinMode(BTN_RIGHT, INPUT_PULLUP);
    pinMode(BTN_BACK, INPUT_PULLUP);
    bootMs = millis();
    u8g2.begin();
    u8g2.setContrast(200);
    // Splash
    for (int x = 128; x >= 0; x -= 10) {
        u8g2.clearBuffer();
        u8g2.setFont(u8g2_font_logisoso16_tr);
        u8g2.drawStr(x + 4, 26, "DIY");
        u8g2.setFont(u8g2_font_6x10_tr);
        u8g2.drawStr(x + 4, 42, "BRUCE");
        u8g2.sendBuffer();
        delay(15);
    }
    delay(300);
    drawMainMenu();
}

void loop() {
    if (state == ST_MAIN) {
        if (btn(BTN_LEFT)) {
            mainIdx = (mainIdx - 1 + MCNT) % MCNT;
            subIdx = 0;
            subScroll = 0;
            drawMainMenu();
        } else if (btn(BTN_RIGHT)) {
            mainIdx = (mainIdx + 1) % MCNT;
            subIdx = 0;
            subScroll = 0;
            drawMainMenu();
        } else if (btn(BTN_OK) || btn(BTN_DOWN)) {
            animDown();
            state = ST_SUB;
            subIdx = 0;
            subScroll = 0;
            drawSubMenu();
        }
    } else if (state == ST_SUB) {
        MainItem& m = menu[mainIdx];
        if (btn(BTN_UP)) {
            subIdx = (subIdx - 1 + m.cnt) % m.cnt;
            drawSubMenu();
        } else if (btn(BTN_DOWN)) {
            subIdx = (subIdx + 1) % m.cnt;
            drawSubMenu();
        } else if (btn(BTN_OK)) {
            executeAction();
            drawSubMenu();
        } else if (btn(BTN_BACK)) {
            animUp();
            state = ST_MAIN;
            drawMainMenu();
        }
    }
    delay(20);
}
'''

# ==================== ФУНКЦІЇ ДЛЯ СТВОРЕННЯ ПУСТИХ МОДУЛІВ ====================
def create_empty_module(module_name, functions):
    h_content = f'''#ifndef {module_name.upper()}_H
#define {module_name.upper()}_H

// ==================== {module_name} ====================
'''
    cpp_content = f'''#include "{module_name}.h"
#include <Arduino.h>

'''
    for func in functions:
        h_content += f'void {func}();\n'
        cpp_content += f'''void {func}() {{
    Serial.println("{func} called");
}}
'''
    h_content += '\n#endif\n'
    return h_content, cpp_content

# Список функцій для кожного модуля
WIFI_FUNCTIONS = ['initWiFiAttack', 'startWiFiScan', 'startWiFiDeauth', 'startWiFiBeacon', 'startEvilTwin', 'startHandshakeSniffer', 'startWiFiJammer', 'startWiFiMonitor', 'startWiFiInfo', 'stopWiFiAttack']
